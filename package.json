{
  "name": "affer-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev:core": "pnpm --filter @clxd/affer dev",
    "build:core": "pnpm --filter @clxd/affer build",
    "dev:docs": "pnpm --filter docs dev",
    "build:docs": "pnpm --filter docs build",
    "dev": "pnpm --parallel dev",
    "build": "pnpm build:core && pnpm build:docs",
    "deploy": "pnpm build && pnpm --filter docs exec wrangler deploy"
  },
  "overrides": {
    "vite": "^7.2.0"
  },
  "devDependencies": {
    "wrangler": "^4.95.0"
  }
}