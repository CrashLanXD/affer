{
  "name": "zyphora-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "build:core": "pnpm --filter zyphora build",
    "build:docs": "pnpm --filter zyphora-docs build",
    "build": "pnpm build:core && pnpm build:docs",
    "deploy": "pnpm build && pnpm --filter zyphora-docs exec wrangler deploy"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.2.0"
    }
  },
  "devDependencies": {
    "wrangler": "^4.95.0"
  }
}