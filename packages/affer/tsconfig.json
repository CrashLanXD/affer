{
  "extends": "../../tsconfig.json",

  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "types": ["vite/client"],

    "paths": {
      "~/*": ["./src/*"]
    },

    "useDefineForClassFields": true,
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,

    "noEmit": true
  },

  "include": ["src"]
}