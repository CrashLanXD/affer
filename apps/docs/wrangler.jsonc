{
	"compatibility_date": "2026-05-13",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "zyphora-js",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"routes": [
		{
			"pattern": "zyphora.clxd.dev",
			"custom_domain": true
		}
	],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}