---
import Welcome from "../components/Welcome.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <Welcome />
  <div class="w-full flex justify-center items-center relative h-dvh">
    <div class="w-full mb-0 h-full absolute bottom-0 mix-blend-difference sl:mix-blend-darken">
      <canvas id="art" class="art w-full opacity-0"
        data-config='{"slices":1,"effectType":"none","isMouseLocked":true,"fitParent":true}'
      ></canvas>
    </div>
    <div class="container font-pixel-square animate-fade-in mx-auto">
      <h1 class="text-fluid">Zyphora<span class="text-p">.js</span></h1>
    </div>
  </div>
</Layout>

<style>
  :root {
    &[data-theme="dark"] {
      --artFill: #000;
      --artStroke: var(--color-p);
    }
    &[data-theme="light"] {
      --artFill: #e5e4d1;
      --artStroke: #111111;
    }
  }

  h1 {
    --text-f-base-min: 20;
    --text-f-base-max: 25;
    --text-f-ratio-min: 1.15;
    --text-f-level: 7;
    text-align: center;
  }
</style>

<script>
  import type { MathArtCanvas } from "@crashlanxd/math-art";
  import { Ticker, MouseTracker, lerp } from 'zyphora';

  const CONFIGS = [
    {"count":200,"shape":"rect","scale":1.5,"velocity":0.4,"freq":7,"twist":0,"twirl":0.1,"lump":-0.05,"noise":0,"ampX":5,"ampY":1,"zoom":1.95,"top":15,"left":0,"axis":"x","aspectRatio":1.2,"mouseX":0.825,"mouseY":0.255},
    {"count":80,"shape":"ellipse","scale":1.8,"velocity":0.85,"freq":2,"twist":11,"twirl":0.007,"lump":0.2,"noise":0.5,"ampX":-1,"ampY":1,"zoom":1.95,"top":0,"left":0,"axis":"x","aspectRatio":2.389,"isBalls":true,"mouseX":0.02,"mouseY":0.2},
    {"count":150,"shape":"ellipse","scale":2.5,"velocity":0.4,"freq":5,"twist":0.5,"twirl":0.001,"lump":0.235,"noise":0,"ampX":0,"ampY":2.5,"zoom":1.95,"top":25,"left":0,"axis":"x","aspectRatio":1.5,"mouseX":1,"mouseY":0.568},
    {"count":106,"shape":"rect","scale":0.5,"velocity":0.4,"freq":1,"twist":0,"twirl":0.5,"lump":0,"noise":0,"ampX":2.8,"ampY":2.8,"zoom":1.8,"top":-50,"left":10,"axis":"xy","aspectRatio":1,"slices":6,"effectType":"starburst","mouseX":0.8674768518518519,"mouseY":0.58}
  ];

  let heroInstance: AbortController | null = null;
  let mouse: MouseTracker | null = null;
  let tickCallback: (() => void) | null = null;

  document.addEventListener("astro:page-load", () => {
    const canvas = document.querySelector("#art") as MathArtCanvas | null;
    if (!canvas) return;

    if (heroInstance) heroInstance.abort();
    heroInstance = new AbortController();
    const signal = heroInstance.signal;

    let BASE_X = 0.5;
    let BASE_Y = 0.5;
    const NUDGE_INTENSITY = 0.15; // Máximo de alteración posicional
    const LERP_FACTOR = 0.08;     // Velocidad de transición interna de Zyphora

    let currentX = BASE_X;
    let currentY = BASE_Y;
    
    // 1. Añadimos una variable para controlar la fuerza del mouse de manera fluida
    let mouseInfluence = 0; 
    let isMouseOverCanvas = false;

    canvas.addEventListener('mouseenter', () => { isMouseOverCanvas = true; }, { signal });
    canvas.addEventListener('mouseleave', () => { isMouseOverCanvas = false; }, { signal });

    let canvasRect = canvas.getBoundingClientRect();
    const updateCanvasRect = () => {
      if (canvas) canvasRect = canvas.getBoundingClientRect();
    };

    window.addEventListener("resize", updateCanvasRect, { passive: true, signal });
    window.addEventListener("scroll", updateCanvasRect, { passive: true, signal });

    const initHeroCanvas = () => {
      if (!canvas.artInstance) return;
      canvas.artInstance.setConfig(CONFIGS[Math.floor(Math.random() * CONFIGS.length)] as any);
      canvas.artInstance.setConfig("isMouseLocked", true);
      BASE_X = canvas.artInstance.config.mouseX;
      BASE_Y = canvas.artInstance.config.mouseY;

      currentX = BASE_X;
      currentY = BASE_Y;
      mouseInfluence = 0; // Reiniciar influencia al cambiar de config
      updateCanvasRect(); 
      canvas.artInstance.onReady(() => canvas.classList.add("animate-fade-in"));
    };

    if (canvas.artInstance) initHeroCanvas();
    else canvas.addEventListener("art-ready", initHeroCanvas, { once: true, signal });

    // Instanciamos el MouseTracker pasándole tu factor de suavizado
    mouse = new MouseTracker({ lerpFactor: LERP_FACTOR });

    tickCallback = () => {
      if (!canvas.artInstance || !mouse) return;

      // 2. Calculamos el objetivo de la influencia: 1 si está dentro, 0 si está fuera
      const targetInfluence = (isMouseOverCanvas && mouse.inputType === 'mouse') ? 1 : 0;
      
      // 3. Suavizamos la influencia frame a frame usando el lerp de Zyphora
      mouseInfluence = lerp(mouseInfluence, targetInfluence, LERP_FACTOR);

      // 4. IMPORTANTE: Usamos 'lerpCentered' en lugar de 'centered' para absorber
      // el ruido de lectura por hardware del ratón.
      const deltaX = mouse.lerpCentered.x;
      const deltaY = -mouse.lerpCentered.y; 

      // 5. La posición actual se calcula aplicando el porcentaje de influencia actual.
      // Cuando mouseInfluence es 0, currentX es exactamente BASE_X.
      currentX = BASE_X + (deltaX * NUDGE_INTENSITY * mouseInfluence);
      currentY = BASE_Y + (deltaY * NUDGE_INTENSITY * mouseInfluence);

      // Enviamos las coordenadas limpias y fluidas al motor de arte
      canvas.artInstance.setConfig({ mouseX: currentX, mouseY: currentY });
    };

    Ticker.add(tickCallback);
  });

  document.addEventListener("astro:before-preparation", () => {
    if (heroInstance) heroInstance.abort();
    if (tickCallback) {
      Ticker.remove(tickCallback);
      tickCallback = null;
    }
    if (mouse) {
      mouse.destroy();
      mouse = null;
    }
  });
</script>