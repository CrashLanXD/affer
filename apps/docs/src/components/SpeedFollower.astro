---
---

<div
  id="mouse-follower"
  class="fixed top-0 left-0 pointer-events-none z-9999 opacity-0 will-change-transform transition-opacity duration-200 select-none flex items-center gap-1.5 bg-neutral-900/90 text-white font-mono text-[10px] px-2 py-1 rounded-none border border-neutral-700 shadow-lg"
>
  <!-- <div class="w-1.5 h-1.5 rounded-full bg-purple-500 animate-pulse"></div> -->
  <span id="follower-speed">0 px/s</span>
</div>

<script>
  import { Ticker } from "@clxd/affer";
  import { $mouse } from "@/stores/input-store";

  let abortController: AbortController | null = null;

  document.addEventListener("astro:page-load", () => {
    const follower = document.querySelector("#mouse-follower") as HTMLDivElement | null;
    const speedText = document.querySelector("#follower-speed") as HTMLSpanElement | null;
    
    if (!follower || !speedText) return;

    if (abortController) abortController.abort();
    abortController = new AbortController();
    const { signal } = abortController;

    const mouse = $mouse.get();

    const tick = () => {
      if (!mouse || !mouse.isInside || mouse.inputType !== "mouse") {
        follower.classList.add("opacity-0");
        return;
      }

      follower.classList.remove("opacity-0");

      const posX = mouse.px.x + 12;
      const posY = mouse.px.y + 12;
      
      follower.style.transform = `translate3d(${posX}px, ${posY}px, 0)`;
      speedText.innerText = `${Math.round(mouse.velocity)} px/s`;
    };

    Ticker.add(tick);

    signal.addEventListener("abort", () => {
      Ticker.remove(tick);
    });
  });

  document.addEventListener("astro:before-preparation", () => {
    if (abortController) abortController.abort();
  });
</script>
